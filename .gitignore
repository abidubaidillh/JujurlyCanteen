# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Python backend output — excluded from Next.js watcher via next.config.ts
# These directories are written to at runtime and must not trigger Fast Refresh
ai-detector/output/
ai-detector/debug_frames/
output/
debug_frames/

.kiro/
.vscode/
 ai-detector/app/services/__pycache__/supabase_service.cpython-314.pyc
